# Web
PORT=3000
NODE_ENV=production

# Persistent data directory inside the container.
WORDPRESS_DUPLICATOR_DATA_DIR=/data

# Postgres for execution history, audit logs and saved clone profiles.
# Example inside CapRover:
# postgresql://wordpressduplicator:CHANGE_ME@srv-captain--wordpress-duplicator-db:5432/wordpressduplicator
DATABASE_URL=

# Required before storing encrypted secrets.
# Generate with: openssl rand -base64 32
APP_SECRET_KEY=

# Default execution mode. Keep true until the backend executor is connected and tested.
DRY_RUN_DEFAULT=true

# Optional defaults for the wizard.
DEFAULT_WP_PATH=/var/www/html
CAPROVER_OVERLAY_NETWORK=captain-overlay-network

# Security toggles for future backend execution.
ALLOW_DOCKER_SOCKET=false
ALLOW_STORE_SECRETS=false
